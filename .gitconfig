# Git配置 — 给自动化系统用的Git规则

# 用户信息
git config user.name "Automation System"
git config user.email "auto@aplant.local"

# 推荐配置
git config core.autocrlf true
git config core.safecrlf warn
git config pull.rebase true

# 分支策略
# main: 稳定分支，只从feature分支合并
# feature/*: 功能开发分支
# fix/*: 修复分支
# checkpoint/*: 自动检查点分支（系统自动创建）

# 提交信息规范
# 类型: [WIP|FEAT|FIX|REFACTOR|DOCS|CHORE]
# 格式: <type>: <简短描述>
# 示例: FEAT: 实现视频帧提取模块

# 检查点提交格式（系统自动生成）
# WIP: <任务ID> - <任务摘要>
# 
# [gstack-context]
# Decisions: <关键决策>
# Remaining: <剩余工作>
# [/gstack-context]
